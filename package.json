{
  "name": "optimap",
  "displayName": "OptiMap",
  "description": "Visualizing and optimizing your code flow with interactive maps.",
  "version": "0.0.1",
  "icon": "resources/logo.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "optimap-explorer",
          "title": "OptiMap",
          "icon": "resources/sidebar.png"
        }
      ]
    },
    "commands": [
      {
        "command": "optimap.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "optimap.analyze",
        "title": "OptiMap: Analyze AI Workflow Paths"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}

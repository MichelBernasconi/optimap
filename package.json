{
  "name": "optimap",
  "displayName": "OptiMap",
  "description": "The ultimate visualizer for AI Agent Workflows. Optimize paths, detect loops, and focus on bottlenecks.",
  "version": "0.1.0",
  "publisher": "MichelBernasconi",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichelBernasconi/optimap.git"
  },
  "homepage": "https://michelbernasconi.ch/optimap",
  "bugs": {
    "url": "https://github.com/MichelBernasconi/optimap/issues"
  },
  "qna": "marketplace",
  "keywords": [
    "ai",
    "workflow",
    "visualization",
    "optimizer",
    "d3js",
    "automation",
    "agentic",
    "graphs",
    "productivity"
  ],
  "icon": "resources/logo.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
           "activitybar": [
                {
                    "id": "optimap-explorer",
                    "title": "OptiMap",
                    "icon": "resources/optimap-icon.svg"
                }
            ]
    },
    "views": {
      "optimap-explorer": [
                {
                    "type": "webview",
                    "id": "optimap.view",
                    "name": "OptiMap Dashboard",
                    "icon": "resources/optimap-icon.svg"
                }
      ]
    },
    "commands": [
      {
        "command": "optimap.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "optimap.analyze",
        "title": "OptiMap: Analyze AI Workflow Paths"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
